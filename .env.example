# ─────────────────────────────────────────────────────────────────────────────
# Self-serve CLEAR app — environment variables
# Copy to `.env.local` for local dev. Client vars MUST be prefixed VITE_ (Vite
# only exposes import.meta.env.VITE_*). Server secrets live in Supabase Edge
# Function secrets, never in the client bundle.
# ─────────────────────────────────────────────────────────────────────────────

# --- Client (safe to expose; shipped in the browser bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (from the Stripe dashboard). Subscriptions + one-off unlock.
VITE_STRIPE_PRICE_SOLO=
VITE_STRIPE_PRICE_TEAM=
VITE_STRIPE_PRICE_BUSINESS=
VITE_STRIPE_PRICE_UNLOCK=
VITE_APP_URL=http://localhost:8080
VITE_BILLING_ENABLED=true
# stub = canned fixtures (no API key needed); live = call Claude via edge fn
VITE_AI_MODE=stub

# --- Edge Function secrets (set with: supabase secrets set KEY=value) ---
# SUPABASE_URL / SUPABASE_ANON_KEY are injected automatically into functions.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
AI_MODE=stub
# Read model ids from env so they can be upgraded without code changes.
CLARIFY_MODEL=claude-haiku-4-5
LEVERAGE_MODEL=claude-sonnet-4-6
EXPERIMENT_MODEL=claude-sonnet-4-6
# RESEARCH agent: model for the web-search run + the (cheap) de-identification model used on promotion.
RESEARCH_MODEL=claude-sonnet-4-6
DEIDENTIFY_MODEL=claude-haiku-4-5
FEATURE_EXPERIMENT=false
RAG_ENABLED=false
# Per-workspace monthly spend cap (USD) enforced before live runs.
WORKSPACE_MONTHLY_COST_CAP_USD=25
# Optional: restrict promoting findings into the shared knowledge_base to one
# (operator/admin) workspace id. Leave blank to let any project owner promote.
OPERATOR_WORKSPACE_ID=
